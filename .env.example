# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=aa_user
POSTGRES_PASSWORD=aa_pass
POSTGRES_DB=apologetics_africa

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_this_nextauth_secret_in_production

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_FROM=noreply@apologeticsafrica.com

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
